FROM public.ecr.aws/lambda/python:3.11@sha256:d044e45093a29946e452fe0f20bf8536fb50c6a1b25f9f0f7a854323d598454f

# Install uv and copy dependency metadata first for better caching
RUN pip install --no-cache-dir uv==0.6.13
COPY pyproject.toml uv.lock ${LAMBDA_TASK_ROOT}/
RUN cd ${LAMBDA_TASK_ROOT} && UV_PROJECT_ENVIRONMENT=/var/lang uv sync --locked --no-dev

# Copy function code
COPY . ${LAMBDA_TASK_ROOT}

# Set environment variables for Lambda
ENV PYTHONPATH=${LAMBDA_TASK_ROOT}

# Set the CMD to your handler (the lambda_main.handler function)
CMD ["lambda_main.handler"]
